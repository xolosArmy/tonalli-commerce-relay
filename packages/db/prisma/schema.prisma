generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  address   String   @unique
  alias     String?  @unique
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthChallenge {
  id        String    @id @default(uuid())
  nonce     String    @unique
  domain    String
  address   String
  alias     String?
  purpose   String
  network   String
  version   String
  issuedAt  DateTime
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([address])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([revokedAt])
  @@index([domain, address])
}

model Order {
  id                 String         @id
  buyerUserId        String
  intermediaryUserId String?
  arbitratorUserId   String?
  moderatorUserId    String?
  status             String
  disputeStatus      String
  product            Json
  quote              Json
  createdAt          DateTime
  updatedAt          DateTime
  escrowRecord       EscrowRecord?
  events             OrderEvent[]
  evidence           OrderEvidence[]
  dispute            Dispute?

  @@index([status])
  @@index([buyerUserId])
  @@index([intermediaryUserId])
  @@index([createdAt])
}

model EscrowRecord {
  id              String   @id @default(uuid())
  orderId         String   @unique
  escrowAddress   String?
  escrowScriptHex String?
  depositTxid     String?
  releaseTxid     String?
  refundTxid      String?
  nonce           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([depositTxid])
  @@index([releaseTxid])
  @@index([refundTxid])
}

model OrderEvent {
  id          String   @id @default(uuid())
  orderId     String
  type        String
  actorUserId String?
  payload     Json?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([type])
  @@index([createdAt])
  @@index([orderId, createdAt])
}

model OrderEvidence {
  id                 String   @id @default(uuid())
  orderId            String
  type               String
  uri                String?
  hash               String?
  notes              String?
  externalReference  String?
  submittedByUserId  String?
  submittedAt        DateTime
  createdAt          DateTime @default(now())
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([type])
  @@index([submittedByUserId])
  @@index([submittedAt])
  @@index([orderId, submittedAt])
}

model Dispute {
  id               String         @id @default(uuid())
  orderId          String         @unique
  status           String
  openedByUserId   String
  reason           String
  openedAt         DateTime
  resolvedByUserId String?
  resolution       String?
  authority        String?
  resolvedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events           DisputeEvent[]

  @@index([status])
  @@index([openedByUserId])
  @@index([resolvedByUserId])
  @@index([openedAt])
  @@index([resolvedAt])
}

model DisputeEvent {
  id          String   @id @default(uuid())
  disputeId   String
  type        String
  actorUserId String?
  payload     Json?
  createdAt   DateTime @default(now())
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([type])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([disputeId, createdAt])
}


model ReputationProfile {
  id                      String   @id @default(uuid())
  userId                  String   @unique @map("user_id")
  alias                   String?  @unique
  address                 String
  level                   String
  score                   Int
  completedOrders         Int      @map("completed_orders")
  completedEligibleOrders Int      @map("completed_eligible_orders")
  totalVolumeXec          Decimal  @map("total_volume_xec")
  totalVolumeFiatMxn      Decimal  @map("total_volume_fiat_mxn")
  openDisputes            Int      @map("open_disputes")
  wonDisputes             Int      @map("won_disputes")
  lostDisputes            Int      @map("lost_disputes")
  maxOrderFiatMxn         Decimal  @map("max_order_fiat_mxn")
  maxDailyFiatMxn         Decimal  @map("max_daily_fiat_mxn")
  isFrozen                Boolean  @default(false) @map("is_frozen")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([score])
  @@index([level])
  @@map("reputation_profiles")
}

model ReputationEvent {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  type          String
  orderId       String?  @map("order_id")
  volumeXec     Decimal? @map("volume_xec")
  volumeFiatMxn Decimal? @map("volume_fiat_mxn")
  reason        String?
  occurredAt    DateTime @map("occurred_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([occurredAt])
  @@map("reputation_events")
}

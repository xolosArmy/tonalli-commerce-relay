generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  address   String   @unique
  alias     String?  @unique
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthChallenge {
  id        String    @id @default(uuid())
  nonce     String    @unique
  domain    String
  address   String
  alias     String?
  purpose   String
  network   String
  version   String
  issuedAt  DateTime
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([address])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([revokedAt])
  @@index([domain, address])
}
